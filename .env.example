# ============================================================
# SSSD Security Lab - Environment Configuration Example
# ============================================================
# Copy this file to .env and fill in your actual values
# NEVER commit the .env file to the repository!
# ============================================================

# Application Configuration
PORT=3000
NODE_ENV=development
APP_BASE_URL=http://localhost:3000

# ============================================================
# Database Configuration (MySQL)
# ============================================================
DB_HOST=your_database_host
DB_PORT=3306
DB_NAME=your_database_name
DB_USER=your_database_user
DB_PASSWORD=your_database_password

# Example for local development:
# DB_HOST=localhost
# DB_PORT=3306
# DB_NAME=sssd_database
# DB_USER=root
# DB_PASSWORD=

# ============================================================
# SMS/2FA Configuration (Infobip)
# ============================================================
# For SMS verification and 2FA code delivery
INFOBIP_BASE_URL=https://YOUR_API_BASE_URL.api.infobip.com
INFOBIP_AUTHORIZATION=App YOUR_INFOBIP_API_KEY_HERE
SMS_SENDER_NAME=YourSenderName

# How to get Infobip credentials:
# 1. Sign up at https://www.infobip.com/
# 2. Create an API key in your dashboard
# 3. Copy the base URL and authorization key

# ============================================================
# 2FA Configuration
# ============================================================
# Timeout for 2FA sessions (in milliseconds)
# Default: 600000 (10 minutes)
2FA_TIMEOUT=600000

# ============================================================
# SECURITY NOTES
# ============================================================
# - Always use strong, unique passwords for database and API keys
# - Never share your .env file
# - Rotate API keys regularly
# - Use environment-specific credentials for each deployment
# - In production, use proper secrets management (AWS Secrets Manager, etc.)
